<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STA - Short Term Alpha</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:-apple-system,BlinkMacSystemFont,sans-serif;
}

body{
background:#0f0f0f;
color:#fff;
padding:20px;
}

.header{
margin-bottom:30px;
}

.logo{
font-size:34px;
font-weight:700;
}

.sub{
color:#888;
margin-top:5px;
}

.refresh{
width:100%;
border:none;
padding:14px;
background:#fff;
color:#111;
border-radius:12px;
font-weight:700;
margin-bottom:20px;
cursor:pointer;
}

.card{
background:#1a1a1a;
padding:18px;
border-radius:18px;
margin-bottom:15px;
border:1px solid #2b2b2b;
}

.rank{
font-size:20px;
font-weight:700;
margin-bottom:10px;
}

.stock{
font-size:24px;
font-weight:700;
margin-bottom:15px;
}

.info{
display:flex;
justify-content:space-between;
margin-bottom:8px;
color:#d8d8d8;
}

.reason{
margin-top:15px;
color:#9e9e9e;
line-height:1.5;
}

.footer{
text-align:center;
margin-top:30px;
color:#666;
font-size:13px;
}
</style>
</head>

<body>

<div class="header">
<div class="logo">STA</div>
<div class="sub">Short Term Alpha</div>
</div>

<button class="refresh" onclick="loadStocks()">
오늘의 단타 TOP3 새로고침
</button>

<div id="stocks"></div>

<div class="footer">
News Based Short-Term Picks
</div>

<script>

function randomPrice(min,max){
return Math.floor(Math.random()*(max-min)+min);
}

function loadStocks(){

const stocks = [

{
name:"두산에너빌리티",
reason:"원전 관련 뉴스 및 수급 강세"
},

{
name:"한화시스템",
reason:"방산 수주 기대감"
},

{
name:"현대로템",
reason:"방산 및 철도 수출 모멘텀"
},

{
name:"LS ELECTRIC",
reason:"전력 인프라 투자 확대"
},

{
name:"HD현대일렉트릭",
reason:"전력기기 업종 강세"
}

];

stocks.sort(()=>0.5-Math.random());

let html="";

for(let i=0;i<3;i++){

let current=randomPrice(50000,150000);

let target=Math.floor(current*1.05);

let stop=Math.floor(current*0.97);

html+=`

<div class="card">

<div class="rank">
🥇 TOP ${i+1}
</div>

<div class="stock">
${stocks[i].name}
</div>

<div class="info">
<span>현재가</span>
<span>${current.toLocaleString()}원</span>
</div>

<div class="info">
<span>목표가</span>
<span>${target.toLocaleString()}원</span>
</div>

<div class="info">
<span>손절가</span>
<span>${stop.toLocaleString()}원</span>
</div>

<div class="reason">
${stocks[i].reason}
</div>

</div>

`;
}

document.getElementById("stocks").innerHTML=html;

}

loadStocks();

</script>

</body>
</html>
